# Backend env (server only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/spotify/callback
LASTFM_API_KEY=your_lastfm_api_key
YOUTUBE_API_KEY=your_youtube_data_api_key

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

ETLAB_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/etlab/callback
ETLAB_SKIP_SSL_VERIFY=false
ETLAB_MOCK_MODE=false

SESSION_COOKIE_SECURE=false

FRONTEND_ORIGIN=http://127.0.0.1:5173
ADMIN_EMAILS=admin@example.com
ADMIN_ETLAB_IDS=240752
HTTP_TIMEOUT_SECONDS=10
